# ═══════════════════════════════════════════════════════════════
# Susurros de la Mina - .gitignore
# ═══════════════════════════════════════════════════════════════

# Godot 4+ specific ignores
.godot/
/android/
/export/
/builds/

# Imported resources (regenerated by Godot)
*.import

# Godot specific
*.translation
*.res
*.tres
!resources/**/*.tres

# System files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# Temporary files
*.tmp
*.bak
*.log

# Build artifacts
*.pck
*.zip
*.exe
*.dll
*.so
*.dylib

# Export templates
templates/

# Asset temporary files
*.blend1
*.blend2
*.bak

# Cache
.cache/
*.cache

# Local configuration
config.cfg
local.cfg
